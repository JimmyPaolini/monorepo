{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "lexico-entities",
  "projectType": "library",
  "sourceRoot": "packages/lexico-entities",
  "tags": [
    "domain:lexico",
    "framework:nestjs",
    "framework:typeorm",
    "language:typescript",
    "type:package"
  ],
  "targets": {
    "analyze-code": {},
    "build": {
      "executor": "@nx/vite:build",
      "options": {
        "outputPath": "dist/packages/lexico-entities"
      },
      "outputs": ["{options.outputPath}"]
    },
    "clean": {},
    "dependency-cruiser": {},
    "eslint": {},
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "migration": {
      "configurations": {
        "extract-sql-all": {
          "command": "pnpm exec tsx packages/lexico-entities/scripts/extract-migration-sql.ts --mode=all",
          "cwd": "{workspaceRoot}"
        },
        "extract-sql-latest": {
          "command": "pnpm exec tsx packages/lexico-entities/scripts/extract-migration-sql.ts --mode=latest",
          "cwd": "{workspaceRoot}"
        },
        "generate": {
          "commands": [
            "pnpm --filter lexico-entities exec node --import @swc-node/register/esm-register node_modules/typeorm/cli.js migration:generate \"src/modules/database/migrations/migration\" -d src/modules/database/data-source.ts",
            "nx run lexico-entities:migration:extract-sql-latest",
            "nx run lexico-entities:lint:write",
            "nx run lexico-entities:format:write"
          ],
          "parallel": false
        },
        "revert": {
          "command": "pnpm --filter lexico-entities exec node --import @swc-node/register/esm-register node_modules/typeorm/cli.js migration:revert -d src/modules/database/data-source.ts"
        },
        "run": {
          "command": "pnpm --filter lexico-entities exec node --import @swc-node/register/esm-register node_modules/typeorm/cli.js migration:run -d src/modules/database/data-source.ts"
        },
        "show": {
          "command": "pnpm --filter lexico-entities exec node --import @swc-node/register/esm-register node_modules/typeorm/cli.js migration:show -d src/modules/database/data-source.ts"
        }
      },
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}/packages/lexico-entities"
      }
    },
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "sqlfluff-format": {},
    "sqlfluff-lint": {},
    "squawk": {},
    "test": {},
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
