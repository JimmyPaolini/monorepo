{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "lexico-entities",
  "projectType": "library",
  "sourceRoot": "packages/lexico-entities",
  "tags": [
    "domain:lexico",
    "framework:nestjs",
    "framework:typeorm",
    "language:typescript"
  ],
  "targets": {
    "analyze-code": {},
    "build": {
      "executor": "@nx/vite:build",
      "options": {
        "outputPath": "dist/packages/lexico-entities"
      },
      "outputs": ["{options.outputPath}"]
    },
    "clean": {},
    "dependency-cruiser": {},
    "eslint": {},
    "format": {},
    "knip": {},
    "lint": {
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:eslint:check",
            "nx run {projectName}:oxlint:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:eslint:write",
            "nx run {projectName}:oxlint:write"
          ],
          "parallel": false
        }
      }
    },
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
