{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "target": "esnext",
    "types": ["node"]
  },
  "exclude": ["dist", "node_modules"],
  "extends": "../../configuration/tsconfig.json",
  "include": [
    "*.config.mts",
    "eslint.config.ts",
    "scripts/**/*.ts",
    "src/**/*.ts"
  ]
}
