{
  "compilerOptions": {
    "declaration": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "../../dist/out-tsc",
    "paths": {
      "@/*": ["./src/*"],
      "eslint-plugin-better-max-params": [
        "../../configuration/types/eslint-plugin-better-max-params/index.d.ts"
      ],
      "monorepo/configuration/*": ["../../configuration/*"]
    },
    "types": ["node", "vite/client"]
  },
  "extends": "../../configuration/tsconfig.json",
  "include": [
    "eslint.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.mts"
  ]
}
