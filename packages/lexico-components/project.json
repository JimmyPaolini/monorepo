{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "lexico-components",
  "projectType": "library",
  "sourceRoot": "packages/lexico-components/src",
  "tags": [
    "framework:react",
    "language:typescript",
    "scope:shared",
    "type:lib"
  ],
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "options": {
        "outputPath": "dist/packages/lexico-components"
      },
      "outputs": ["{options.outputPath}"]
    },
    "bundlesize": {
      "cache": true,
      "dependsOn": ["build"],
      "description": "Check bundle size limits",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/dist/packages/lexico-components/**/*",
        "default"
      ],
      "options": {
        "command": "npx size-limit",
        "cwd": "packages/lexico-components"
      }
    },
    "clean": {},
    "code-analysis": {},
    "dependency-analysis": {},
    "format": {},
    "knip": {},
    "lint": {
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:eslint:check",
            "nx run {projectName}:oxlint:check",
            "nx run {projectName}:stylelint:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:eslint:write",
            "nx run {projectName}:oxlint:write",
            "nx run {projectName}:stylelint:write"
          ],
          "parallel": false
        }
      }
    },
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "stylelint": {},
    "type-coverage": {},
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "yaml-lint": {}
  }
}
