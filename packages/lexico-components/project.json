{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "lexico-components",
  "projectType": "library",
  "sourceRoot": "packages/lexico-components/src",
  "tags": [
    "framework:react",
    "language:typescript",
    "scope:shared",
    "type:lib"
  ],
  "targets": {
    "biome-format": {},
    "biome-lint": {},
    "build": {
      "executor": "@nx/vite:build",
      "options": {
        "outputPath": "dist/packages/lexico-components"
      },
      "outputs": ["{options.outputPath}"]
    },
    "bundlesize": {
      "cache": true,
      "dependsOn": ["build"],
      "description": "Check bundle size limits",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/dist/packages/lexico-components/**/*",
        "default"
      ],
      "options": {
        "command": "npx size-limit",
        "cwd": "packages/lexico-components"
      }
    },
    "code-analysis": {
      "options": {
        "commands": [
          "nx run {projectName}:dependency-analysis",
          "nx run {projectName}:format:{args.configuration}",
          "nx run {projectName}:knip:{args.configuration}",
          "nx run {projectName}:lint:{args.configuration}",
          "nx run {projectName}:markdown-lint:{args.configuration}",
          "nx run {projectName}:spell-check",
          "nx run {projectName}:type-coverage",
          "nx run {projectName}:typecheck",
          "nx run {projectName}:yaml-lint"
        ]
      }
    },
    "dependency-analysis": {},
    "format": {},
    "knip": {},
    "lint": {
      "options": {
        "commands": [
          "nx run {projectName}:eslint:{args.configuration}",
          "nx run {projectName}:oxlint:{args.configuration}",
          "nx run {projectName}:stylelint:{args.configuration}"
        ]
      }
    },
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "stylelint": {},
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
