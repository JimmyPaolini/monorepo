GH_TOKEN=""
GITHUB_TOKEN=""
TF_VAR_linode_kubernetes_engine_cluster_id=""
TF_VAR_linode_token=""

# Environment: "local" | "devcontainer-local" | "devcontainer-cloud"
MONOREPO_ENVIRONMENT="local"

# Service URLs (defaults for local development; devcontainer overrides via remoteEnv)
OLLAMA_HOST="http://localhost:11434"
SEARXNG_HOST="http://localhost:8889"

# PostgreSQL (used by docker-compose and lexico-ingestion)
POSTGRES_DB=postgres
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
