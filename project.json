{
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "name": "monorepo",
  "projectType": "application",
  "targets": {
    "analyze-code": {
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:clean:check",
            "nx run {projectName}:format:check",
            "nx run {projectName}:lint:check",
            "nx run {projectName}:markdown-lint:check",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:sync-agent-skills:check",
            "nx run {projectName}:sync-conventional-config:check",
            "nx run {projectName}:sync-pull-request-template:check",
            "nx run {projectName}:sync-vscode-extensions:check",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:clean:write",
            "nx run {projectName}:format:write",
            "nx run {projectName}:lint:write",
            "nx run {projectName}:markdown-lint:write",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:sync-agent-skills:write",
            "nx run {projectName}:sync-conventional-config:write",
            "nx run {projectName}:sync-pull-request-template:write",
            "nx run {projectName}:sync-vscode-extensions:write",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck"
          ],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "description": "Run all static code analysis tools for workspace root (typecheck, lint, format, clean, spell-check, markdown-lint, yaml-lint)",
      "executor": "nx:run-commands",
      "options": {}
    },
    "audit-security": {
      "cache": false,
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:gitleaks",
            "nx affected --target=bandit --parallel=3 --base=main --head=HEAD",
            "nx run {projectName}:scan-dependencies:check",
            "nx run {projectName}:trivy"
          ],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "description": "Run comprehensive security audit: Gitleaks (secrets), Bandit (Python/affected), npm/pnpm audit (dependencies), and Trivy (containers/IaC). Mirrors .github/workflows/audit-security.yml",
      "executor": "nx:run-commands",
      "options": {}
    },
    "check-lockfile": {
      "description": "Verify that pnpm-lock.yaml is in sync with package.json files",
      "executor": "nx:run-commands",
      "options": {
        "command": "bash scripts/check-lockfile.sh",
        "cwd": "{projectRoot}"
      }
    },
    "clean": {
      "cache": true,
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:knip:check",
            "nx run {projectName}:vulture:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:knip:write",
            "nx run {projectName}:vulture:write"
          ],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "description": "Run unused-code analysis for workspace-root files only across JavaScript, TypeScript, and Python",
      "executor": "nx:run-commands",
      "options": {}
    },
    "commitlint": {
      "cache": false,
      "description": "Validate commit message format with commitlint (invoked by the commit-msg git hook)",
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_OPTIONS='--import=tsx' commitlint --config configuration/commitlint.config.ts --edit {args.edit}",
        "cwd": "{projectRoot}"
      }
    },
    "eslint": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "eslint {args} --config configuration/eslint.config.base.ts --no-error-on-unmatched-pattern '*.ts' '*.js' '*.json' '*.md' 'scripts/' 'documentation/' 'infrastructure/'"
        },
        "write": {
          "command": "eslint {args} --fix --config configuration/eslint.config.base.ts --no-error-on-unmatched-pattern '*.ts' '*.js' '*.json' '*.md' 'scripts/' 'documentation/' 'infrastructure/'"
        }
      },
      "defaultConfiguration": "check",
      "description": "Lint workspace root files with ESLint (config files, scripts, documentation, infrastructure, markdown)",
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "format": {
      "configurations": {
        "check": {
          "commands": [
            "nx run monorepo:prettier:check",
            "nx run monorepo:oxfmt:check",
            "nx run monorepo:sqlfluff-format:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run monorepo:prettier:write",
            "nx run monorepo:oxfmt:write",
            "nx run monorepo:sqlfluff-format:write"
          ],
          "parallel": false
        }
      }
    },
    "gitleaks": {
      "cache": true,
      "configurations": {
        "ci": {
          "command": "gitleaks git --verbose --redact --config configuration/gitleaks.toml --gitleaks-ignore-path configuration"
        }
      },
      "description": "Detect hardcoded secrets in git history using Gitleaks (detection only)",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/.gitleaksignore",
        "{workspaceRoot}/configuration/gitleaks.toml",
        "default"
      ],
      "options": {
        "command": "gitleaks git --staged --verbose --redact --config configuration/gitleaks.toml --gitleaks-ignore-path configuration",
        "cwd": "{projectRoot}"
      }
    },
    "knip": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "knip --config configuration/knip.config.ts --workspace ."
        },
        "write": {
          "command": "knip --config configuration/knip.config.ts --fix --workspace ."
        }
      },
      "defaultConfiguration": "check",
      "description": "Check for unused files, dependencies, and exports in workspace root only",
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "license-check": {
      "cache": true,
      "description": "Check licenses of production dependencies",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/package.json",
        "{workspaceRoot}/pnpm-lock.yaml",
        "default"
      ],
      "options": {
        "command": "license-checker --json --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD;CC0-1.0;Unlicense;Python-2.0;CC-BY-3.0;CC-BY-4.0;WTFPL;Zlib;BlueOak-1.0.0' --production --excludePrivatePackages",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "configurations": {
        "check": {
          "commands": [
            "nx run monorepo:eslint:check",
            "nx run monorepo:oxlint:check",
            "nx run monorepo:sqlfluff-lint:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run monorepo:eslint:write",
            "nx run monorepo:oxlint:write",
            "nx run monorepo:sqlfluff-lint:write"
          ],
          "parallel": false
        }
      }
    },
    "lint-staged": {
      "cache": false,
      "description": "Run lint-staged on staged files (invoked by the pre-commit git hook)",
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_OPTIONS='--import=tsx' lint-staged --config configuration/lint-staged.config.ts --continue-on-error --no-stash",
        "cwd": "{projectRoot}"
      }
    },
    "markdown-lint": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "markdownlint-cli2 --config configuration/.markdownlint-cli2.jsonc '*.md' 'scripts/**/*.md' 'documentation/**/*.md' 'infrastructure/**/*.md'"
        },
        "write": {
          "command": "markdownlint-cli2 --fix --config configuration/.markdownlint-cli2.jsonc '*.md' 'scripts/**/*.md' 'documentation/**/*.md' 'infrastructure/**/*.md'"
        }
      },
      "defaultConfiguration": "check",
      "description": "Lint markdown files in workspace root (scripts, documentation, infrastructure)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/*.md",
        "{projectRoot}/documentation/**/*.md",
        "{projectRoot}/infrastructure/**/*.md",
        "{projectRoot}/scripts/**/*.md",
        "{workspaceRoot}/configuration/.markdownlint-cli2.jsonc",
        "default"
      ],
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "oxfmt": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "oxfmt -c configuration/oxfmt.config.ts {args} '*.ts' '*.js' '*.json' '*.md' 'scripts/' 'documentation/' 'infrastructure/'"
        },
        "write": {
          "command": "oxfmt -c configuration/oxfmt.config.ts {args} '*.ts' '*.js' '*.json' '*.md' 'scripts/' 'documentation/' 'infrastructure/'"
        }
      },
      "defaultConfiguration": "check",
      "description": "Format workspace root files with oxfmt (config files, scripts, documentation, infrastructure)",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/configuration/oxfmt.config.ts", "default"],
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "oxlint": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "oxlint --config configuration/oxlint.config.ts '*.ts' '*.js' 'scripts/' 'documentation/' 'infrastructure/' --ignore-pattern='infrastructure/helm/**/templates'"
        },
        "write": {
          "command": "oxlint --config configuration/oxlint.config.ts {args} '*.ts' '*.js' 'scripts/' 'documentation/' 'infrastructure/' --ignore-pattern='infrastructure/helm/**/templates'"
        }
      },
      "defaultConfiguration": "check",
      "description": "Run Oxlint on workspace root files (config files, scripts, documentation, infrastructure)",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/configuration/oxlint.config.ts", "default"],
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "pnpm-audit": {
      "cache": false,
      "configurations": {
        "check": {
          "command": "pnpm audit --audit-level=moderate --ignore-unfixable"
        },
        "write": {
          "command": "jq 'del(.pnpm.overrides)' package.json > package.tmp.json && mv package.tmp.json package.json && pnpm update --no-frozen-lockfile && pnpm audit --fix --ignore-unfixable; pnpm install --no-frozen-lockfile"
        }
      },
      "defaultConfiguration": "check",
      "description": "Scan for fixable security vulnerabilities (check) or clean stale overrides and re-fix (write)",
      "executor": "nx:run-commands",
      "options": {}
    },
    "postgres": {
      "configurations": {
        "down": {
          "command": "docker compose -f infrastructure/docker/docker-compose.yml down postgres"
        },
        "recreate": {
          "command": "docker compose -f infrastructure/docker/docker-compose.yml down -v postgres && docker compose -f infrastructure/docker/docker-compose.yml up -d postgres"
        },
        "up": {
          "command": "docker compose -f infrastructure/docker/docker-compose.yml up -d postgres"
        }
      },
      "defaultConfiguration": "up",
      "description": "Start, stop, or recreate the local PostgreSQL container (recreate removes the volume)",
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}"
      }
    },
    "prettier": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "prettier {args} --config configuration/prettier.config.ts --ignore-path .prettierignore --check --ignore-unknown ."
        },
        "write": {
          "command": "prettier {args} --config configuration/prettier.config.ts --ignore-path .prettierignore --write --ignore-unknown ."
        }
      },
      "defaultConfiguration": "write",
      "description": "Format workspace root files with Prettier (excluding NX projects)",
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier {args} --config configuration/prettier.config.ts --ignore-path .prettierignore --ignore-unknown .",
        "cwd": "{projectRoot}"
      }
    },
    "scan-dependencies": {
      "cache": false,
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:license-check",
            "nx run {projectName}:pnpm-audit:check",
            "nx run {projectName}:sherif:check",
            "nx run {projectName}:syncpack:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:upgrade-dependencies:write",
            "nx run {projectName}:license-check",
            "nx run {projectName}:pnpm-audit:write",
            "nx run {projectName}:sherif:write",
            "nx run {projectName}:syncpack:write"
          ],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "description": "Run all dependency management tools (pnpm-audit, license-check, sherif, syncpack). Dependency upgrades are handled separately by upgrade-dependencies.",
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "sherif": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "pnpm dlx sherif@1.10.0 -p applications/JimmyPaolini"
        },
        "write": {
          "command": "pnpm dlx sherif@1.10.0 -p applications/JimmyPaolini --fix && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Lint monorepo for consistent package.json conventions",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/**/package.json"],
      "options": {
        "cwd": "{workspaceRoot}"
      }
    },
    "spell-check": {
      "cache": true,
      "description": "Check spelling in workspace root files (scripts, documentation, infrastructure, planning)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/*.{ts,tsx,js,jsx,md,yaml,yml,json}",
        "{projectRoot}/documentation/**",
        "{projectRoot}/infrastructure/**",
        "{projectRoot}/planning/**",
        "{projectRoot}/scripts/**",
        "{workspaceRoot}/configuration/cspell.config.yaml",
        "default"
      ],
      "options": {
        "command": "cspell --config configuration/cspell.config.yaml '*.{ts,tsx,js,jsx,md,yaml,yml,json}' 'scripts/**' 'documentation/**' 'infrastructure/**' 'planning/**' --no-progress --gitignore",
        "cwd": "{projectRoot}"
      }
    },
    "sqlfluff-format": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "lint"
        },
        "write": {
          "args": "fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/scripts/database/*.sql",
        "{workspaceRoot}/configuration/pyproject.toml",
        "sharedGlobals"
      ],
      "options": {
        "command": "uv run --project configuration sqlfluff {args} --config configuration/pyproject.toml scripts/database",
        "cwd": "{workspaceRoot}"
      }
    },
    "sqlfluff-lint": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "lint"
        },
        "write": {
          "args": "fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/scripts/database/*.sql",
        "{workspaceRoot}/configuration/pyproject.toml",
        "sharedGlobals"
      ],
      "options": {
        "command": "uv run --project configuration sqlfluff {args} --config configuration/pyproject.toml scripts/database",
        "cwd": "{workspaceRoot}"
      }
    },
    "sync-agent-skills": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "tsx scripts/sync-agent-skills.ts check"
        },
        "write": {
          "command": "tsx scripts/sync-agent-skills.ts write && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Validate that agent skills table of contents is synchronized from documentation/skills/*/SKILL.md into AGENTS.md (check) or sync them (write)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/AGENTS.md",
        "{projectRoot}/documentation/skills/**/*.md"
      ],
      "options": {
        "command": "tsx scripts/sync-agent-skills.ts"
      }
    },
    "sync-conformance-generators": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "tsx scripts/sync-conformance-generators.ts check"
        },
        "write": {
          "command": "tsx scripts/sync-conformance-generators.ts write && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Validate that conformance generators table is synchronized from tools/conformance/generators.json into AGENTS.md (check) or sync them (write)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/AGENTS.md",
        "{workspaceRoot}/tools/conformance/generators.json"
      ],
      "options": {
        "command": "tsx scripts/sync-conformance-generators.ts"
      }
    },
    "sync-conventional-config": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "tsx scripts/sync-conventional-config.ts check"
        },
        "write": {
          "command": "tsx scripts/sync-conventional-config.ts write && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Validate that conventional commit config (types/scopes) is synchronized from conventional.config.cjs into .vscode/settings.json and SKILL.md (check) or sync them (write)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/.vscode/settings.json",
        "{projectRoot}/configuration/conventional.config.cjs",
        "{projectRoot}/documentation/skills/commit-code/SKILL.md"
      ],
      "options": {
        "command": "tsx scripts/sync-conventional-config.ts"
      }
    },
    "sync-devcontainer-configuration": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "tsx scripts/sync-devcontainer-configuration.ts check"
        },
        "write": {
          "command": "tsx scripts/sync-devcontainer-configuration.ts write && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Validate that common fields in cloud devcontainer.json are in sync with the local config (check) or propagate them (write)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/.devcontainer/cloud/devcontainer.json",
        "{projectRoot}/.devcontainer/local/devcontainer.json"
      ],
      "options": {
        "command": "tsx scripts/sync-devcontainer-configuration.ts"
      }
    },
    "sync-pull-request-template": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "tsx scripts/sync-pull-request-template.ts check"
        },
        "write": {
          "command": "tsx scripts/sync-pull-request-template.ts write && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Validate that the PR template is synchronized from .github/PULL_REQUEST_TEMPLATE.md into skills and prompt files (check) or sync them (write)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/.github/prompts/create-pull-request.prompt.md",
        "{projectRoot}/.github/prompts/update-pull-request.prompt.md",
        "{projectRoot}/.github/PULL_REQUEST_TEMPLATE.md",
        "{projectRoot}/documentation/skills/create-pull-request/SKILL.md"
      ],
      "options": {
        "command": "tsx scripts/sync-pull-request-template.ts"
      }
    },
    "sync-vscode-extensions": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "tsx .devcontainer/scripts/sync-vscode-extensions.ts check"
        },
        "write": {
          "command": "tsx .devcontainer/scripts/sync-vscode-extensions.ts write && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Validate that VS Code extensions are synchronized between .vscode/extensions.json and both devcontainer configurations (check) or sync them (write)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/.devcontainer/cloud/devcontainer.json",
        "{projectRoot}/.devcontainer/local/devcontainer.json",
        "{projectRoot}/.vscode/extensions.json"
      ],
      "options": {
        "command": "tsx .devcontainer/scripts/sync-vscode-extensions.ts"
      }
    },
    "sync-vscode-settings": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "tsx .devcontainer/scripts/sync-vscode-settings.ts check"
        },
        "write": {
          "command": "tsx .devcontainer/scripts/sync-vscode-settings.ts write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Validate that VS Code Machine settings contain all workspace settings (check) or merge workspace settings into Machine settings (write)",
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/.vscode/settings.json"],
      "options": {
        "command": "tsx .devcontainer/scripts/sync-vscode-settings.ts"
      }
    },
    "syncpack": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "pnpm exec syncpack lint --config configuration/syncpack.config.cjs"
        },
        "write": {
          "command": "pnpm exec syncpack fix --config configuration/syncpack.config.cjs && nx run monorepo:format:write"
        }
      },
      "defaultConfiguration": "check",
      "description": "Check dependency version consistency across packages (check) or fix mismatches (write)",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/**/package.json",
        "{workspaceRoot}/configuration/syncpack.config.cjs",
        "{workspaceRoot}/pnpm-lock.yaml"
      ],
      "options": {
        "command": "pnpm exec syncpack lint --config configuration/syncpack.config.cjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "terraform": {
      "cache": false,
      "configurations": {
        "import": {
          "command": "terraform import -input=false linode_lke_cluster.my_cluster $TF_VAR_linode_kubernetes_engine_cluster_id"
        },
        "plan": {
          "command": "terraform plan"
        }
      },
      "defaultConfiguration": "plan",
      "description": "Run Terraform commands (plan, import)",
      "executor": "nx:run-commands",
      "options": {
        "command": "terraform plan",
        "cwd": "infrastructure/terraform"
      }
    },
    "trivy": {
      "cache": false,
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:trivy-image",
            "nx run {projectName}:trivy-config"
          ],
          "parallel": true
        }
      },
      "defaultConfiguration": "check",
      "description": "Run all Trivy security scans (container images and infrastructure config)",
      "executor": "nx:run-commands",
      "options": {}
    },
    "trivy-config": {
      "cache": false,
      "description": "Scan Terraform infrastructure code for misconfigurations using Trivy",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/infrastructure/terraform/**/*.tf"],
      "options": {
        "command": "trivy config infrastructure/terraform --severity CRITICAL,HIGH --exit-code 1 --ignorefile configuration/trivyignore",
        "cwd": "{projectRoot}"
      }
    },
    "type-coverage": {
      "cache": true,
      "description": "Check TypeScript type coverage for workspace root (minimum 95%)",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx}",
        "{workspaceRoot}/tsconfig.json",
        "default"
      ],
      "options": {
        "command": "type-coverage --at-least 95 --detail --project tsconfig.json",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "description": "Type-check workspace root TypeScript files",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "{projectRoot}"
      }
    },
    "upgrade-dependencies": {
      "cache": false,
      "configurations": {
        "check": {
          "command": "pnpm outdated --recursive"
        },
        "write": {
          "command": "pnpm update --latest --recursive"
        }
      },
      "defaultConfiguration": "check",
      "description": "Check for dependency updates (check) or upgrade all dependencies to latest versions (write)",
      "executor": "nx:run-commands",
      "options": {}
    },
    "validate-branch-name": {
      "cache": false,
      "description": "Validate the current branch name against the configured naming convention (invoked by the pre-push git hook)",
      "executor": "nx:run-commands",
      "options": {
        "command": "validate-branch-name",
        "cwd": "{projectRoot}"
      }
    },
    "vulture": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {}
      },
      "defaultConfiguration": "check",
      "description": "Check root-level Python utilities for dead code",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/*.py",
        "{projectRoot}/scripts/**/*.py",
        "{workspaceRoot}/applications/affirmations/pyproject.toml",
        "{workspaceRoot}/configuration/vulture_whitelist.py",
        "default"
      ],
      "options": {
        "command": "uv run --project applications/affirmations vulture . configuration/vulture_whitelist.py --min-confidence 80 --exclude '*/applications/*,*/packages/*,*/tools/*,*/node_modules/*,*/dist/*,*/coverage/*,*/.venv/*'",
        "cwd": "{projectRoot}"
      }
    },
    "yaml-lint": {}
  }
}
