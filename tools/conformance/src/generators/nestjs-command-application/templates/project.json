{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "{{nameKebabCase}}",
  "projectType": "application",
  "sourceRoot": "applications/{{nameKebabCase}}",
  "tags": [
    "framework:nest-commander",
    "framework:nestjs",
    "generator:nestjs-command-application",
    "language:typescript"
  ],
  "targets": {
    "analyze-code": {},
    "clean": {},
    "dependency-cruiser": {},
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "repl": {
      "description": "Start the {{namePascalCase}} application in REPL mode",
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import @swc-node/register/esm-register src/repl.ts",
        "cwd": "${projectRoot}"
      }
    },
    "spell-check": {},
    "start": {
      "description": "Start the {{namePascalCase}} application",
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import @swc-node/register/esm-register src/main.ts {{nameKebabCase}}",
        "cwd": "${projectRoot}"
      }
    },
    "test": {
      "configurations": {
        "coverage": {
          "command": "vitest run --coverage"
        },
        "end-to-end": {
          "command": "vitest run end-to-end.test.ts"
        },
        "integration": {
          "command": "vitest run integration.test.ts"
        },
        "unit": {
          "command": "vitest run unit.test.ts"
        },
        "watch": {
          "command": "vitest"
        }
      },
      "description": "Run all tests",
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "${projectRoot}"
      }
    },
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
