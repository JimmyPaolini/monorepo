{
  "$schema": "http://json-schema.org/schema",
  "properties": {
    "destinationRoot": {
      "default": "applications",
      "description": "Root directory where the application will be generated",
      "enum": ["applications", "packages", "tools"],
      "type": "string",
      "x-prompt": {
        "items": [
          {
            "label": "applications",
            "value": "applications"
          },
          {
            "label": "tools",
            "value": "tools"
          },
          {
            "label": "packages",
            "value": "packages"
          }
        ],
        "message": "Where should the NestJS command application be generated?",
        "type": "list"
      }
    },
    "name": {
      "description": "The name of the application (kebab-case)",
      "type": "string",
      "x-prompt": "What is the name of the application? (kebab-case)"
    }
  },
  "type": "object"
}
