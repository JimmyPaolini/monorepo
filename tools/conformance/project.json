{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "conformance",
  "projectType": "application",
  "sourceRoot": "tools/conformance",
  "tags": [
    "framework:nest-commander",
    "framework:nestjs",
    "generator:nestjs-command-application",
    "language:typescript",
    "type:application"
  ],
  "targets": {
    "analyze-code": {},
    "clean": {},
    "code-analysis": {},
    "dependency-cruiser": {},
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "test": {},
    "type-coverage": {},
    "typecheck": {},
    "validate": {
      "description": "Run workspace conformance validation",
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NODE_OPTIONS node --import @swc-node/register/esm-register src/main.ts validator {args}",
        "cwd": "{projectRoot}"
      }
    },
    "yaml-lint": {}
  }
}
