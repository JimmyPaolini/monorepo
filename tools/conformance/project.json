{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "conformance",
  "prefix": "lib",
  "projectType": "library",
  "sourceRoot": "tools/conformance/src",
  "tags": ["language:python", "language:typescript", "type:tool"],
  "targets": {
    "analyze-code": {},
    "build": {
      "cache": true,
      "description": "No-op build target for development tool",
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'conformance is a development tool and does not require building'"
      }
    },
    "clean": {},
    "code-analysis": {},
    "dependency-cruiser": {
      "executor": "nx:run-commands",
      "options": {
        "command": "depcruise tools/conformance/src --exclude '^tools/conformance/src/generators/.*/templates/' --config configuration/dependency-cruiser.cjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "format": {
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:prettier:check",
            "nx run {projectName}:oxfmt:check",
            "nx run {projectName}:ruff-format:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:prettier:write",
            "nx run {projectName}:oxfmt:write",
            "nx run {projectName}:ruff-format:write"
          ],
          "parallel": false
        }
      },
      "executor": "nx:run-commands"
    },
    "knip": {},
    "lint": {
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:eslint:check",
            "nx run {projectName}:oxlint:check",
            "nx run {projectName}:ruff-lint:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:eslint:write",
            "nx run {projectName}:oxlint:write",
            "nx run {projectName}:ruff-lint:write"
          ],
          "parallel": false
        }
      },
      "executor": "nx:run-commands"
    },
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --ignore-pattern='**/templates/**' tools/conformance/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "prettier": {},
    "pyright": {},
    "pytest": {},
    "ruff-format": {},
    "ruff-lint": {},
    "spell-check": {},
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run {projectName}:vitest",
          "nx run {projectName}:pytest"
        ],
        "parallel": true
      }
    },
    "type-coverage": {},
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --noEmit -p tsconfig.json",
          "nx run {projectName}:pyright"
        ],
        "cwd": "{projectRoot}",
        "parallel": true
      }
    },
    "vitest": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run {args.args}",
        "cwd": "tools/conformance"
      }
    },
    "yaml-lint": {}
  }
}
