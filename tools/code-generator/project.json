{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "code-generator",
  "prefix": "lib",
  "projectType": "library",
  "sourceRoot": "tools/code-generator/src",
  "tags": ["language:typescript", "type:util"],
  "targets": {
    "biome-format": {},
    "biome-lint": {},
    "build": {
      "cache": true,
      "description": "No-op build target for development tool",
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'code-generator is a development tool and does not require building'"
      }
    },
    "code-analysis": {
      "options": {
        "commands": [
          "nx run {projectName}:dependency-analysis",
          "nx run {projectName}:format:{args.configuration}",
          "nx run {projectName}:knip:{args.configuration}",
          "nx run {projectName}:lint:{args.configuration}",
          "nx run {projectName}:spell-check",
          "nx run {projectName}:type-coverage",
          "nx run {projectName}:typecheck"
        ]
      }
    },
    "dependency-analysis": {},
    "eslint": {
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/eslint.config.base.mjs", "default"],
      "options": {
        "command": "eslint tools/code-generator --no-error-on-unmatched-pattern --ignore-pattern '**/code-generator/**/files/**'"
      }
    },
    "format": {},
    "knip": {},
    "lint": {},
    "oxfmt": {},
    "oxlint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --ignore-pattern='**/files/**' tools/code-generator/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "prettier": {},
    "spell-check": {},
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run {args.args}",
        "cwd": "tools/code-generator"
      }
    },
    "type-coverage": {},
    "typecheck": {}
  }
}
