{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "code-generator",
  "prefix": "lib",
  "projectType": "library",
  "sourceRoot": "tools/code-generator/src",
  "tags": ["language:typescript", "type:util"],
  "targets": {
    "biome-format": {},
    "biome-lint": {},
    "build": {
      "cache": true,
      "description": "No-op build target for development tool",
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'code-generator is a development tool and does not require building'"
      }
    },
    "clean": {},
    "code-analysis": {
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:clean:check",
            "nx run {projectName}:dependency-analysis",
            "nx run {projectName}:format:check",
            "nx run {projectName}:lint:check",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:clean:write",
            "nx run {projectName}:dependency-analysis",
            "nx run {projectName}:format:write",
            "nx run {projectName}:lint:write",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck"
          ],
          "parallel": false
        }
      }
    },
    "dependency-analysis": {},
    "eslint": {
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/eslint.config.base.mjs", "default"],
      "options": {
        "command": "eslint tools/code-generator --no-error-on-unmatched-pattern --ignore-pattern '**/code-generator/**/files/**'"
      }
    },
    "format": {},
    "knip": {
      "configurations": {
        "check": {
          "commands": ["nx run {projectName}:knip:check"],
          "parallel": true
        },
        "write": {
          "commands": ["nx run {projectName}:knip:write"],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands"
    },
    "lint": {},
    "oxfmt": {},
    "oxlint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --ignore-pattern='**/files/**' tools/code-generator/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "prettier": {},
    "spell-check": {},
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run {args.args}",
        "cwd": "tools/code-generator"
      }
    },
    "type-coverage": {},
    "typecheck": {}
  }
}
