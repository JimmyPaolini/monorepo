{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "code-generator",
  "prefix": "lib",
  "projectType": "library",
  "sourceRoot": "tools/code-generator/src",
  "tags": ["language:typescript", "type:util"],
  "targets": {
    "build": {
      "cache": true,
      "description": "No-op build target for development tool",
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'code-generator is a development tool and does not require building'"
      }
    },
    "clean": {},
    "code-analysis": {},
    "dependency-cruiser": {},
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --ignore-pattern='**/templates/**' tools/code-generator/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "prettier": {},
    "pytest": {
      "cache": true,
      "configurations": {
        "coverage": {
          "command": "uv run pytest --cov=src --cov-report=xml:coverage/python.xml --cov-report=term-missing"
        }
      },
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest",
        "cwd": "{projectRoot}"
      }
    },
    "spell-check": {},
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run {args.args}",
        "cwd": "tools/code-generator"
      }
    },
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
