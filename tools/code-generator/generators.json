{
  "$schema": "http://json-schema.org/draft-07/schema",
  "generators": {
    "nestjs-service-module": {
      "aliases": ["nsm"],
      "description": "Generate a NestJS service module with module, service, types, constants, and unit test files",
      "factory": "./src/generators/nestjs-service-module/generator#generateNestjsServiceModule",
      "schema": "./src/generators/nestjs-service-module/schema.json"
    },
    "react-component": {
      "aliases": ["c"],
      "description": "Generate a React component with test file",
      "factory": "./src/generators/react-component/generator#generateComponent",
      "schema": "./src/generators/react-component/schema.json"
    }
  }
}
