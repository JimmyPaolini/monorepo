{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@golevelup/ts-vitest": [
        "./node_modules/@golevelup/ts-vitest/lib/index.d.ts"
      ],
      "@synchronization/*": ["./*"],
      "eslint-plugin-better-max-params": [
        "../../configuration/types/eslint-plugin-better-max-params/index.d.ts"
      ],
      "monorepo/configuration/*": ["../../configuration/*"]
    },
    "target": "esnext",
    "types": ["node", "vitest/globals"]
  },
  "exclude": ["dist", "node_modules", "output"],
  "extends": "../../configuration/tsconfig.json",
  "include": [
    "eslint.config.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "testing/**/*.ts",
    "vitest.config.ts"
  ]
}
