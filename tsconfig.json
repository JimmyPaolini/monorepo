{
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "monorepo/configuration/*": ["./configuration/*"]
    },
    "skipLibCheck": true
  },
  "exclude": [
    "applications",
    "dist",
    "node_modules",
    "packages",
    "tmp",
    "tools"
  ],
  "extends": "./configuration/tsconfig.base.json",
  "include": [
    "*.ts",
    ".devcontainer/scripts/**/*.ts",
    "configuration/**/*.ts",
    "scripts/**/*.ts"
  ]
}
