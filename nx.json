{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "bail": false,
  "cacheDirectory": ".nx/cache",
  "defaultBase": "main",
  "excludedGlobs": ["**/tools/conformance/src/modules/*/templates/**"],
  "generators": {
    "@nx/react": {
      "application": {
        "babel": true,
        "bundler": "vite",
        "linter": "eslint",
        "style": "tailwind"
      },
      "component": {
        "style": "tailwind"
      },
      "library": {
        "linter": "eslint",
        "style": "tailwind"
      }
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "shared-globals"],
    "production": [
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "default"
    ],
    "python-source": [
      "{projectRoot}/**/*.ipynb",
      "{projectRoot}/**/*.py",
      "{projectRoot}/pyproject.toml"
    ],
    "python-tests": ["{projectRoot}/testing/**/*.py"],
    "shared-globals": [
      "{workspaceRoot}/.github/workflows/*.yml",
      "{workspaceRoot}/configuration/tsconfig.json",
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/pnpm-workspace.yaml"
    ],
    "typescript-files": [
      "{projectRoot}/**/*.{ts,tsx,mts,cts}",
      "{projectRoot}/**/*.json",
      "{projectRoot}/tsconfig*.json",
      "shared-globals"
    ]
  },
  "parallel": 3,
  "plugins": [
    {
      "exclude": ["**/tools/conformance/src/modules/*/templates/**"],
      "options": {
        "buildDepsTargetName": false,
        "buildTargetName": "build",
        "devTargetName": "develop",
        "e2eTestTargetName": false,
        "previewTargetName": false,
        "serveStaticTargetName": false,
        "serveTargetName": false,
        "typecheckTargetName": "typecheck",
        "watchDepsTargetName": false
      },
      "plugin": "@nx/vite/plugin"
    },
    {
      "exclude": ["**/tools/conformance/src/modules/*/templates/**"],
      "options": {
        "targetName": "eslint"
      },
      "plugin": "@nx/eslint/plugin"
    },
    {
      "exclude": ["**/tools/conformance/src/modules/*/templates/**"],
      "plugin": "@nx/vitest"
    }
  ],
  "projects": {
    "caelundas": {
      "tags": ["domain:caelundas", "language:typescript", "type:application"]
    },
    "monorepo": {
      "tags": ["language:typescript", "type:tool"]
    }
  },
  "targetDefaults": {
    "analyze-code": [
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": [
              "nx run {projectName}:clean:check",
              "nx run {projectName}:format:check",
              "nx run {projectName}:lint:check",
              "nx run {projectName}:markdown-lint:check",
              "nx run {projectName}:nbstripout:check",
              "nx run {projectName}:spell-check",
              "nx run {projectName}:typecheck",
              "nx run {projectName}:yaml-lint"
            ],
            "parallel": true
          },
          "write": {
            "commands": [
              "nx run {projectName}:clean:write",
              "nx run {projectName}:format:write",
              "nx run {projectName}:lint:write",
              "nx run {projectName}:markdown-lint:write",
              "nx run {projectName}:nbstripout:write",
              "nx run {projectName}:spell-check",
              "nx run {projectName}:typecheck",
              "nx run {projectName}:yaml-lint"
            ],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:python"]
        },
        "inputs": [
          "{projectRoot}/**/*.{py,ipynb,md,yaml,yml,json}",
          "shared-globals"
        ],
        "options": {
          "outputStyle": "stream"
        }
      },
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": [
              "nx run {projectName}:clean:check",
              "nx run {projectName}:dependency-cruiser",
              "nx run {projectName}:format:check",
              "nx run {projectName}:lint:check",
              "nx run {projectName}:markdown-lint:check",
              "nx run {projectName}:spell-check",
              "nx run {projectName}:type-coverage",
              "nx run {projectName}:typecheck",
              "nx run {projectName}:yaml-lint"
            ],
            "parallel": true
          },
          "write": {
            "commands": [
              "nx run {projectName}:clean:write",
              "nx run {projectName}:dependency-cruiser",
              "nx run {projectName}:format:write",
              "nx run {projectName}:lint:write",
              "nx run {projectName}:markdown-lint:write",
              "nx run {projectName}:spell-check",
              "nx run {projectName}:type-coverage",
              "nx run {projectName}:typecheck",
              "nx run {projectName}:yaml-lint"
            ],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:typescript"]
        },
        "inputs": [
          "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml,sql}",
          "shared-globals"
        ],
        "options": {
          "outputStyle": "stream"
        }
      }
    ],
    "bandit": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["python-source"],
      "options": {
        "command": "uv run bandit -c pyproject.toml -r src/",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["^production", "production"]
    },
    "clean": [
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": ["nx run {projectName}:vulture:check"],
            "parallel": true
          },
          "write": {
            "commands": ["nx run {projectName}:vulture:write"],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:python"]
        },
        "inputs": ["python-source", "shared-globals"]
      },
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": ["nx run {projectName}:knip:check"],
            "parallel": true
          },
          "write": {
            "commands": ["nx run {projectName}:knip:write"],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:typescript"]
        },
        "inputs": [
          "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,py}",
          "{workspaceRoot}/configuration/knip.config.ts",
          "shared-globals"
        ]
      }
    ],
    "code-analysis": {
      "cache": true,
      "description": "Run code analysis checks through the aggregate analyze-code target",
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "options": {
        "command": "nx run {projectName}:analyze-code:check",
        "cwd": "{workspaceRoot}"
      }
    },
    "dependency-cruiser": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "^default",
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{workspaceRoot}/configuration/dependency-cruiser.cjs",
        "default"
      ],
      "options": {
        "command": "depcruise {projectRoot}/src --config configuration/dependency-cruiser.cjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "eslint": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {
          "args": "--fix"
        }
      },
      "defaultConfiguration": "check",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml}",
        "{workspaceRoot}/configuration/eslint.config.ts",
        "shared-globals"
      ],
      "options": {
        "command": "eslint . {args}"
      }
    },
    "fallow": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "shared-globals"
      ]
    },
    "fallow-audit": {
      "cache": false,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "shared-globals"
      ]
    },
    "fallow-dead-code": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "shared-globals"
      ]
    },
    "fallow-duplicates": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "shared-globals"
      ]
    },
    "fallow-health": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "shared-globals"
      ]
    },
    "format": [
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": ["nx run {projectName}:ruff-format:check"],
            "parallel": true
          },
          "write": {
            "commands": ["nx run {projectName}:ruff-format:write"],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:python"]
        },
        "inputs": [
          "{workspaceRoot}/configuration/pyproject.toml",
          "python-source"
        ]
      },
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": [
              "# nx run {projectName}:prettier:check",
              "nx run {projectName}:oxfmt:check"
            ],
            "parallel": true
          },
          "write": {
            "commands": [
              "# nx run {projectName}:prettier:write",
              "nx run {projectName}:oxfmt:write"
            ],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:typescript"]
        },
        "inputs": [
          "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml,sql}",
          "{workspaceRoot}/configuration/.prettierignore",
          "{workspaceRoot}/configuration/oxfmt.config.ts",
          "{workspaceRoot}/configuration/prettier.config.ts",
          "shared-globals"
        ]
      }
    ],
    "knip": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "knip --config configuration/knip.config.ts --workspace {projectRoot}"
        },
        "write": {
          "command": "knip --fix --config configuration/knip.config.ts --workspace {projectRoot}"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/configuration/knip.config.ts", "default"],
      "options": {
        "command": "knip --config configuration/knip.config.ts --workspace {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": [
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": ["nx run {projectName}:ruff-lint:check"],
            "parallel": true
          },
          "write": {
            "commands": ["nx run {projectName}:ruff-lint:write"],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:python"]
        },
        "inputs": [
          "{workspaceRoot}/configuration/pyproject.toml",
          "python-source"
        ]
      },
      {
        "cache": true,
        "configurations": {
          "check": {
            "commands": [
              "nx run {projectName}:eslint:check",
              "nx run {projectName}:oxlint:check"
            ],
            "parallel": true
          },
          "write": {
            "commands": [
              "nx run {projectName}:eslint:write",
              "nx run {projectName}:oxlint:write"
            ],
            "parallel": false
          }
        },
        "defaultConfiguration": "check",
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:typescript"]
        },
        "inputs": [
          "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,md,mdx,css}",
          "{workspaceRoot}/configuration/eslint.config.ts",
          "{workspaceRoot}/configuration/oxlint.config.ts",
          "shared-globals"
        ]
      }
    ],
    "markdown-lint": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "markdownlint-cli2 --config configuration/.markdownlint-cli2.jsonc '{projectRoot}/**/*.md'"
        },
        "write": {
          "command": "markdownlint-cli2 --fix --config configuration/.markdownlint-cli2.jsonc '{projectRoot}/**/*.md'"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.md",
        "{workspaceRoot}/configuration/.markdownlint-cli2.jsonc",
        "shared-globals"
      ],
      "options": {
        "command": "markdownlint-cli2 --config configuration/.markdownlint-cli2.jsonc '{projectRoot}/**/*.md'",
        "cwd": "{workspaceRoot}"
      }
    },
    "oxfmt": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "--check"
        },
        "write": {
          "args": "--write"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml}",
        "{workspaceRoot}/configuration/.oxfmtignore",
        "{workspaceRoot}/configuration/oxfmt.config.ts",
        "shared-globals"
      ],
      "options": {
        "command": "oxfmt -c configuration/oxfmt.config.ts --ignore-path configuration/.oxfmtignore {args} {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "oxlint": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {
          "args": "--fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/oxlint.config.ts",
        "shared-globals"
      ],
      "options": {
        "command": "oxlint --config configuration/oxlint.config.ts --ignore-path configuration/.oxlintignore {args} {projectRoot}/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "prettier": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "--check"
        },
        "write": {
          "args": "--write"
        }
      },
      "defaultConfiguration": "write",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml}",
        "{workspaceRoot}/configuration/.prettierignore",
        "{workspaceRoot}/configuration/prettier.config.ts",
        "shared-globals"
      ],
      "options": {
        "command": "prettier {args} --config configuration/prettier.config.ts --ignore-path configuration/.prettierignore {projectRoot}"
      }
    },
    "pyright": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "python-source"
      ],
      "options": {
        "command": "uv run pyright src/",
        "cwd": "{projectRoot}"
      }
    },
    "pytest": {
      "cache": true,
      "configurations": {
        "coverage": {
          "command": "uv run pytest --cov=src --cov-report=xml:coverage/python.xml --cov-report=term-missing"
        },
        "integration": {
          "command": "uv run pytest -m integration"
        },
        "unit": {
          "command": "uv run pytest -m unit"
        },
        "watch": {
          "command": "uv run pytest-watch"
        }
      },
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "python-source",
        "python-tests"
      ],
      "options": {
        "command": "uv run pytest",
        "cwd": "{projectRoot}"
      }
    },
    "ruff-format": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "--check"
        },
        "write": {}
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "python-source"
      ],
      "options": {
        "command": "uv run ruff format {args} .",
        "cwd": "{projectRoot}"
      }
    },
    "ruff-lint": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {
          "args": "--fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "python-source"
      ],
      "options": {
        "command": "uv run ruff check {args} .",
        "cwd": "{projectRoot}"
      }
    },
    "spell-check": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,css,scss,html,yaml,yml,md,mdx,py,ipynb,sql}",
        "{workspaceRoot}/configuration/.cspell/**",
        "{workspaceRoot}/configuration/cspell.config.yaml",
        "shared-globals"
      ],
      "options": {
        "command": "cspell --config configuration/cspell.config.yaml '{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,css,scss,html,yaml,yml,md,mdx,py,ipynb,sql}' --no-progress --gitignore",
        "cwd": "{workspaceRoot}"
      }
    },
    "stylelint": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "stylelint --config ../../configuration/stylelint.config.cjs 'src/**/*.css'"
        },
        "write": {
          "command": "stylelint --fix --config ../../configuration/stylelint.config.cjs 'src/**/*.css'"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**/*.css",
        "{workspaceRoot}/configuration/stylelint.config.cjs"
      ],
      "options": {
        "command": "stylelint --config ../../configuration/stylelint.config.cjs 'src/**/*.css'",
        "cwd": "{projectRoot}"
      }
    },
    "test": [
      {
        "cache": true,
        "configurations": {
          "coverage": {
            "commands": ["nx run {projectName}:pytest:coverage"]
          },
          "integration": {
            "commands": ["nx run {projectName}:pytest:integration"]
          },
          "unit": {
            "commands": ["nx run {projectName}:pytest:unit"]
          },
          "watch": {
            "commands": ["nx run {projectName}:pytest:watch"]
          }
        },
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:python"]
        },
        "inputs": [
          "{workspaceRoot}/configuration/pyproject.toml",
          "python-source",
          "python-tests"
        ],
        "options": {
          "commands": ["nx run {projectName}:pytest"]
        }
      },
      {
        "cache": true,
        "configurations": {
          "coverage": {
            "command": "vitest run --coverage"
          },
          "end-to-end": {
            "command": "vitest run end-to-end.test.ts"
          },
          "integration": {
            "command": "vitest run integration.test.ts"
          },
          "unit": {
            "command": "vitest run unit.test.ts"
          },
          "watch": {
            "command": "vitest"
          }
        },
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:typescript"]
        },
        "inputs": ["^production", "default"],
        "options": {
          "command": "vitest run",
          "cwd": "{projectRoot}"
        }
      }
    ],
    "ty": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "python-source"
      ],
      "options": {
        "command": "uv run ty check src/",
        "cwd": "{projectRoot}"
      }
    },
    "type-coverage": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{projectRoot}/tsconfig.json",
        "shared-globals"
      ],
      "options": {
        "command": "type-coverage --detail > type-coverage-report.txt 2>&1 || (cat type-coverage-report.txt && exit 1)",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/type-coverage-report.txt"]
    },
    "typecheck": [
      {
        "cache": true,
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:python"]
        },
        "inputs": [
          "{workspaceRoot}/configuration/pyproject.toml",
          "python-source"
        ],
        "options": {
          "commands": [
            "nx run {projectName}:pyright",
            "nx run {projectName}:ty"
          ],
          "parallel": true
        }
      },
      {
        "cache": true,
        "executor": "nx:run-commands",
        "filter": {
          "projects": ["tag:language:typescript"]
        },
        "inputs": [
          "^production",
          "typescript-files",
          {
            "externalDependencies": ["typescript"]
          }
        ],
        "options": {
          "command": "tsc --noEmit",
          "cwd": "{projectRoot}"
        },
        "outputs": []
      }
    ],
    "vulture": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {}
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/.vulture_whitelist.py", "python-source"],
      "options": {
        "command": "uv run python -m vulture src/ .vulture_whitelist.py --min-confidence 80",
        "cwd": "{projectRoot}"
      }
    },
    "yaml-lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{yaml,yml}",
        "{workspaceRoot}/configuration/yamllint.yaml",
        "shared-globals"
      ],
      "options": {
        "command": "uv run --project configuration yamllint -c configuration/yamllint.yaml '{projectRoot}'",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tui": {
    "enabled": false
  }
}
