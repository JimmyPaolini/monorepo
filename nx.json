{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "bail": false,
  "cacheDirectory": ".nx/cache",
  "defaultBase": "main",
  "generators": {
    "@nx/react": {
      "application": {
        "babel": true,
        "bundler": "vite",
        "linter": "eslint",
        "style": "tailwind"
      },
      "component": {
        "style": "tailwind"
      },
      "library": {
        "linter": "eslint",
        "style": "tailwind"
      }
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "default"
    ],
    "pythonSource": [
      "{projectRoot}/**/*.ipynb",
      "{projectRoot}/**/*.py",
      "{projectRoot}/pyproject.toml"
    ],
    "pythonTests": ["{projectRoot}/testing/**/*.py"],
    "sharedGlobals": [
      "{workspaceRoot}/.github/workflows/*.yml",
      "{workspaceRoot}/configuration/tsconfig.json",
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/pnpm-lock.yaml"
    ],
    "typescriptFiles": [
      "{projectRoot}/**/*.{ts,tsx,mts,cts}",
      "{projectRoot}/**/*.json",
      "{projectRoot}/tsconfig*.json",
      "sharedGlobals"
    ]
  },
  "parallel": 3,
  "plugins": [
    {
      "options": {
        "buildDepsTargetName": false,
        "buildTargetName": "build",
        "devTargetName": "develop",
        "e2eTestTargetName": false,
        "previewTargetName": false,
        "serveStaticTargetName": false,
        "serveTargetName": false,
        "typecheckTargetName": "typecheck",
        "watchDepsTargetName": false
      },
      "plugin": "@nx/vite/plugin"
    },
    {
      "options": {
        "targetName": "eslint"
      },
      "plugin": "@nx/eslint/plugin"
    },
    {
      "plugin": "@nx/vitest"
    }
  ],
  "projects": {
    "caelundas": {
      "tags": ["domain:caelundas", "language:typescript", "type:application"]
    },
    "monorepo": {
      "tags": ["language:typescript", "type:tool"]
    }
  },
  "targetDefaults": {
    "analyze-code": {
      "cache": true,
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:clean:check",
            "nx run {projectName}:dependency-cruiser",
            "nx run {projectName}:format:check",
            "nx run {projectName}:lint:check",
            "nx run {projectName}:markdown-lint:check",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck",
            "nx run {projectName}:yaml-lint"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:clean:write",
            "nx run {projectName}:dependency-cruiser",
            "nx run {projectName}:format:write",
            "nx run {projectName}:lint:write",
            "nx run {projectName}:markdown-lint:write",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck",
            "nx run {projectName}:yaml-lint"
          ],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml,py,ipynb,sql}",
        "sharedGlobals"
      ],
      "options": {
        "outputStyle": "stream"
      }
    },
    "bandit": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": ["pythonSource"],
      "options": {
        "command": "uv run bandit -c pyproject.toml -r src/",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["^production", "production"]
    },
    "clean": {
      "cache": true,
      "configurations": {
        "check": {
          "commands": ["nx run {projectName}:knip:check"],
          "parallel": true
        },
        "write": {
          "commands": ["nx run {projectName}:knip:write"],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,py}",
        "{workspaceRoot}/configuration/knip.config.ts",
        "sharedGlobals"
      ]
    },
    "dependency-cruiser": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "^default",
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{workspaceRoot}/configuration/dependency-cruiser.cjs",
        "default"
      ],
      "options": {
        "command": "depcruise {projectRoot}/src --config configuration/dependency-cruiser.cjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "eslint": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {
          "args": "--fix"
        }
      },
      "defaultConfiguration": "check",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml}",
        "{workspaceRoot}/configuration/eslint.config.ts",
        "sharedGlobals"
      ],
      "options": {
        "command": "eslint . {args}"
      }
    },
    "fallow": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "sharedGlobals"
      ]
    },
    "fallow-audit": {
      "cache": false,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "sharedGlobals"
      ]
    },
    "fallow-dead-code": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "sharedGlobals"
      ]
    },
    "fallow-duplicates": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "sharedGlobals"
      ]
    },
    "fallow-health": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/fallow.config.jsonc",
        "sharedGlobals"
      ]
    },
    "format": {
      "cache": true,
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:prettier:check",
            "nx run {projectName}:oxfmt:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:prettier:write",
            "nx run {projectName}:oxfmt:write"
          ],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml,sql}",
        "{workspaceRoot}/.prettierignore",
        "{workspaceRoot}/configuration/oxfmt.config.ts",
        "{workspaceRoot}/configuration/prettier.config.ts",
        "sharedGlobals"
      ]
    },
    "knip": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "knip --config configuration/knip.config.ts --workspace {projectRoot}"
        },
        "write": {
          "command": "knip --fix --config configuration/knip.config.ts --workspace {projectRoot}"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/configuration/knip.config.ts", "default"],
      "options": {
        "command": "knip --config configuration/knip.config.ts --workspace {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "cache": true,
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:eslint:check",
            "nx run {projectName}:oxlint:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:eslint:write",
            "nx run {projectName}:oxlint:write"
          ],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,md,mdx,css}",
        "{workspaceRoot}/configuration/eslint.config.ts",
        "{workspaceRoot}/configuration/oxlint.config.ts",
        "sharedGlobals"
      ]
    },
    "markdown-lint": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "markdownlint-cli2 --config configuration/.markdownlint-cli2.jsonc '{projectRoot}/**/*.md'"
        },
        "write": {
          "command": "markdownlint-cli2 --fix --config configuration/.markdownlint-cli2.jsonc '{projectRoot}/**/*.md'"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.md",
        "{workspaceRoot}/configuration/.markdownlint-cli2.jsonc",
        "sharedGlobals"
      ],
      "options": {
        "command": "markdownlint-cli2 --config configuration/.markdownlint-cli2.jsonc '{projectRoot}/**/*.md'",
        "cwd": "{workspaceRoot}"
      }
    },
    "oxfmt": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "--check"
        },
        "write": {
          "args": "--write"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml}",
        "{workspaceRoot}/configuration/oxfmt.config.ts",
        "sharedGlobals"
      ],
      "options": {
        "command": "oxfmt -c configuration/oxfmt.config.ts {args} {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "oxlint": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {
          "args": "--fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}",
        "{workspaceRoot}/configuration/oxlint.config.ts",
        "sharedGlobals"
      ],
      "options": {
        "command": "oxlint --config configuration/oxlint.config.ts {args} {projectRoot}/src",
        "cwd": "{workspaceRoot}"
      }
    },
    "prettier": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "--check"
        },
        "write": {
          "args": "--write"
        }
      },
      "defaultConfiguration": "write",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,html,css,scss,md,mdx,yaml,yml}",
        "{workspaceRoot}/.prettierignore",
        "{workspaceRoot}/configuration/prettier.config.ts",
        "sharedGlobals"
      ],
      "options": {
        "command": "prettier {args} --config configuration/prettier.config.ts --ignore-path .prettierignore {projectRoot}"
      }
    },
    "pyright": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "pythonSource"
      ],
      "options": {
        "command": "uv run pyright src/",
        "cwd": "{projectRoot}"
      }
    },
    "pytest": {
      "cache": true,
      "configurations": {
        "coverage": {
          "command": "uv run pytest --cov=src --cov-report=xml:coverage/python.xml --cov-report=term-missing"
        },
        "integration": {
          "command": "uv run pytest -m integration"
        },
        "unit": {
          "command": "uv run pytest -m unit"
        },
        "watch": {
          "command": "uv run pytest-watch"
        }
      },
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "pythonSource",
        "pythonTests"
      ],
      "options": {
        "command": "uv run pytest",
        "cwd": "{projectRoot}"
      }
    },
    "ruff-format": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "--check"
        },
        "write": {}
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "pythonSource"
      ],
      "options": {
        "command": "uv run ruff format {args} .",
        "cwd": "{projectRoot}"
      }
    },
    "ruff-lint": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {
          "args": "--fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "pythonSource"
      ],
      "options": {
        "command": "uv run ruff check {args} .",
        "cwd": "{projectRoot}"
      }
    },
    "spell-check": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,css,scss,html,yaml,yml,md,mdx,py,ipynb,sql}",
        "{workspaceRoot}/configuration/.cspell/**",
        "{workspaceRoot}/configuration/cspell.config.yaml",
        "sharedGlobals"
      ],
      "options": {
        "command": "cspell --config configuration/cspell.config.yaml '{projectRoot}/**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs,json,jsonc,json5,css,scss,html,yaml,yml,md,mdx,py,ipynb,sql}' --no-progress --gitignore",
        "cwd": "{workspaceRoot}"
      }
    },
    "stylelint": {
      "cache": true,
      "configurations": {
        "check": {
          "command": "stylelint --config ../../configuration/stylelint.config.cjs 'src/**/*.css'"
        },
        "write": {
          "command": "stylelint --fix --config ../../configuration/stylelint.config.cjs 'src/**/*.css'"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**/*.css",
        "{workspaceRoot}/configuration/stylelint.config.cjs"
      ],
      "options": {
        "command": "stylelint --config ../../configuration/stylelint.config.cjs 'src/**/*.css'",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "cache": true,
      "inputs": ["^production", "default"]
    },
    "ty": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{workspaceRoot}/configuration/pyproject.toml",
        "pythonSource"
      ],
      "options": {
        "command": "uv run ty check src/",
        "cwd": "{projectRoot}"
      }
    },
    "type-coverage": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.ts",
        "{projectRoot}/**/*.tsx",
        "{projectRoot}/tsconfig.json",
        "sharedGlobals"
      ],
      "options": {
        "command": "type-coverage --detail > type-coverage-report.txt 2>&1 || (cat type-coverage-report.txt && exit 1)",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/type-coverage-report.txt"]
    },
    "typecheck": {
      "cache": true,
      "inputs": [
        "^production",
        "typescriptFiles",
        {
          "externalDependencies": ["typescript"]
        }
      ],
      "outputs": []
    },
    "vulture": {
      "cache": true,
      "configurations": {
        "check": {},
        "write": {}
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/.vulture_whitelist.py", "pythonSource"],
      "options": {
        "command": "uv run python -m vulture src/ .vulture_whitelist.py --min-confidence 80",
        "cwd": "{projectRoot}"
      }
    },
    "yaml-lint": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.{yaml,yml}",
        "{workspaceRoot}/configuration/yamllint.yaml",
        "sharedGlobals"
      ],
      "options": {
        "command": "uv run --project configuration yamllint -c configuration/yamllint.yaml '{projectRoot}'",
        "cwd": "{workspaceRoot}"
      }
    }
  },
  "tui": {
    "enabled": false
  }
}
