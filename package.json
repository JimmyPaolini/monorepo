{
  "name": "monorepo",
  "version": "1.1.0",
  "description": "Monorepo for JimmyPaolini projects",
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky install",
    "setup": "pnpm install && pnpm exec husky install",
    "dev": "nx run caelundas:develop",
    "build": "nx run-many --target=build --all",
    "build:production": "nx run-many --target=build --prod --all",
    "test": "nx affected --target=test",
    "test:all": "nx run-many --target=test --all",
    "test:watch": "nx affected --target=test -- --watch",
    "format": "nx run-many --target=format --all --parallel=1",
    "format:check": "nx run-many --target=format --configuration=check --all",
    "lint": "nx run-many --target=lint --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "affected": "nx affected:graph",
    "graph": "nx graph",
    "clean": "nx run-many --target=clean --all",
    "version": "nx run monorepo:version"
  },
  "dependencies": {
    "@monorepo/lexico-components": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-form": "^0.37.6",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-router": "^1.46.6",
    "@tanstack/start": "^1.46.6",
    "axios": "^1.7.2",
    "lodash": "^4.17.21",
    "moment-timezone": "^0.5.47",
    "react": "^19.0.0-rc-66cb7c89-20240514",
    "react-dom": "^19.0.0-rc-66cb7c89-20240514",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@monorepo/eslint-config": "workspace:*",
    "@nx/eslint-plugin": "^19.4.0",
    "@nx/vite": "^19.4.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^2.1.0",
    "@supabase/auth-js": "^2.64.4",
    "@swc/core": "^1.5.0",
    "@types/node": "^20.12.12",
    "@types/react": "^19.0.0-rc-66cb7c89-20240514",
    "@types/react-dom": "^19.0.0-rc-66cb7c89-20240514",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "esbuild": "^0.21.4",
    "eslint": "^9.5.0",
    "husky": "^9.0.11",
    "lucide-react": "^0.396.0",
    "nx": "^19.4.0",
    "postcss": "^8.4.38",
    "postgres": "^3.4.4",
    "prettier": "^3.3.2",
    "radix-ui": "^1.0.1",
    "shadcn-ui": "^0.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "sweph": "^2.10.3",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.9",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "allowedNativeDependencies": [
      "@swc/core",
      "esbuild",
      "nx",
      "sqlite3",
      "sweph"
    ],
    "overrides": {
      "axios@<1.15.0": ">=1.15.0",
      "express@<4.18.2": ">=4.18.2",
      "follow-redirects@<1.15.4": ">=1.15.4",
      "glob@<10.3.10": ">=10.3.10",
      "qs@<6.11.2": ">=6.11.2",
      "tar@<6.2.0": ">=6.2.0",
      "trim-newlines@<3.0.1": ">=3.0.1",
      "vite@<=6.4.1": ">=6.4.2",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2"
    },
    "ignoredBuiltDependencies": []
  },
  "repository": "JimmyPaolini/monorepo.git"
}
