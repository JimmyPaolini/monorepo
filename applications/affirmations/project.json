{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "affirmations",
  "projectType": "application",
  "sourceRoot": "applications/affirmations/src",
  "tags": [
    "domain:affirmations",
    "generator:jupyter-notebook-application",
    "language:python",
    "type:application"
  ],
  "targets": {
    "analyze-code": {
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run {projectName}:clean:check",
          "nx run {projectName}:format:check",
          "nx run {projectName}:lint:check",
          "nx run {projectName}:markdown-lint",
          "nx run {projectName}:nbstripout:check",
          "nx run {projectName}:spell-check",
          "nx run {projectName}:typecheck",
          "nx run {projectName}:yaml-lint"
        ],
        "parallel": true
      },
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:clean:check",
            "nx run {projectName}:format:check",
            "nx run {projectName}:lint:check",
            "nx run {projectName}:markdown-lint",
            "nx run {projectName}:nbstripout:check",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:typecheck",
            "nx run {projectName}:yaml-lint"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:clean:write",
            "nx run {projectName}:format:write",
            "nx run {projectName}:lint:write",
            "nx run {projectName}:markdown-lint",
            "nx run {projectName}:nbstripout:write",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:typecheck",
            "nx run {projectName}:yaml-lint"
          ],
          "parallel": false
        }
      }
    },
    "bandit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run bandit -c pyproject.toml -r src",
        "cwd": "{projectRoot}"
      }
    },
    "clean": {
      "configurations": {
        "check": {
          "commands": ["nx run {projectName}:vulture:check"],
          "parallel": true
        },
        "write": {
          "commands": ["nx run {projectName}:vulture:write"],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands"
    },
    "format": {
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx run {projectName}:ruff-format:check"],
        "parallel": true
      },
      "configurations": {
        "check": {
          "commands": ["nx run {projectName}:ruff-format:check"],
          "parallel": true
        },
        "write": {
          "commands": ["nx run {projectName}:ruff-format:write"],
          "parallel": false
        }
      }
    },
    "lint": {
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx run {projectName}:ruff-lint:check"],
        "parallel": true
      },
      "configurations": {
        "check": {
          "commands": ["nx run {projectName}:ruff-lint:check"],
          "parallel": true
        },
        "write": {
          "commands": ["nx run {projectName}:ruff-lint:write"],
          "parallel": false
        }
      }
    },
    "markdown-lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "markdownlint-cli2 --config ../../configuration/.markdownlint-cli2.jsonc '*.md' 'src/**/*.md' 'testing/**/*.md'",
        "cwd": "{projectRoot}"
      }
    },
    "nbstripout": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "--verify"
        },
        "write": {
          "args": ""
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/src/**/*.ipynb"],
      "options": {
        "command": "find src -name '*.ipynb' -exec uv run nbstripout {args} {} +",
        "cwd": "{projectRoot}"
      }
    },
    "ollama": {
      "configurations": {
        "pull-large": {
          "command": "curl -s ${OLLAMA_HOST:-http://localhost:11434}/api/pull -d '{\"name\":\"gemma4:e26b\"}'"
        },
        "pull-medium": {
          "command": "curl -s ${OLLAMA_HOST:-http://localhost:11434}/api/pull -d '{\"name\":\"gemma4:e4b\"}'"
        },
        "pull-small": {
          "command": "curl -s ${OLLAMA_HOST:-http://localhost:11434}/api/pull -d '{\"name\":\"gemma4:e2b\"}'"
        },
        "start": {
          "command": "if [ \"$MONOREPO_ENVIRONMENT\" = \"local\" ]; then brew services start ollama; else echo 'Start Ollama on your host machine: ollama serve (or: brew services start ollama)'; fi"
        },
        "stop": {
          "command": "if [ \"$MONOREPO_ENVIRONMENT\" = \"local\" ]; then brew services stop ollama; else echo 'Stop Ollama on your host machine: pkill ollama (or: brew services stop ollama)'; fi"
        }
      },
      "defaultConfiguration": "start",
      "description": "Manage the native Ollama service running on the host machine",
      "executor": "nx:run-commands",
      "options": {
        "cwd": "applications/affirmations"
      }
    },
    "open-webui": {
      "configurations": {
        "open": {
          "command": "$BROWSER http://localhost:3001"
        },
        "start": {
          "command": "docker compose -f ../../infrastructure/docker/docker-compose.yml up -d open-webui"
        },
        "stop": {
          "command": "docker compose -f ../../infrastructure/docker/docker-compose.yml rm -sf open-webui"
        }
      },
      "defaultConfiguration": "start",
      "description": "Manage the Open WebUI Docker service",
      "executor": "nx:run-commands",
      "options": {
        "cwd": "applications/affirmations"
      }
    },
    "pyright": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pyright src/ testing/",
        "cwd": "{projectRoot}"
      }
    },
    "pytest": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "coverage": {
          "command": "uv run pytest --cov=src --cov-report=term-missing --cov-report=xml"
        },
        "integration": {
          "command": "uv run pytest -m integration"
        },
        "unit": {
          "command": "uv run pytest -m unit"
        }
      },
      "outputs": ["{projectRoot}/coverage.xml"]
    },
    "ruff-format": {
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ruff format --check src/ testing/",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "check": {
          "command": "uv run ruff format --check src/ testing/"
        },
        "write": {
          "command": "uv run ruff format src/ testing/"
        }
      }
    },
    "ruff-lint": {
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ruff check src/ testing/",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "check": {
          "command": "uv run ruff check src/ testing/"
        },
        "write": {
          "command": "uv run ruff check --fix src/ testing/"
        }
      }
    },
    "searxng": {
      "configurations": {
        "open": {
          "command": "$BROWSER http://localhost:8889"
        },
        "start": {
          "command": "docker compose -f ../../infrastructure/docker/docker-compose.yml up -d searxng"
        },
        "stop": {
          "command": "docker compose -f ../../infrastructure/docker/docker-compose.yml rm -sf searxng"
        }
      },
      "defaultConfiguration": "start",
      "description": "Manage the SearxNG Docker service",
      "executor": "nx:run-commands",
      "options": {
        "cwd": "applications/affirmations"
      }
    },
    "spell-check": {
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/*.{md,yaml,yml,json}",
        "{projectRoot}/src/**/*.{py,ipynb,md,yaml,yml,json}",
        "{projectRoot}/testing/**/*.{py,md}",
        "{workspaceRoot}/configuration/cspell.config.yaml"
      ],
      "options": {
        "command": "cspell --config ../../configuration/cspell.config.yaml 'src/**/*.{py,ipynb,md,yaml,yml,json}' 'testing/**/*.{py,md}' '*.{md,yaml,yml,json}' --no-progress",
        "cwd": "applications/affirmations"
      }
    },
    "test": {
      "configurations": {
        "coverage": {
          "commands": ["nx run {projectName}:pytest:coverage"]
        },
        "integration": {
          "commands": ["nx run {projectName}:pytest:integration"]
        },
        "unit": {
          "commands": ["nx run {projectName}:pytest:unit"]
        }
      },
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx run {projectName}:pytest"]
      }
    },
    "ty": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ty check src/",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx run {projectName}:pyright", "nx run {projectName}:ty"],
        "parallel": true
      }
    },
    "vulture": {
      "cache": true,
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run vulture src/ testing/ --min-confidence 80",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "check": {
          "command": "uv run vulture src/ testing/ --min-confidence 80"
        },
        "write": {
          "command": "uv run vulture src/ testing/ --min-confidence 80"
        }
      }
    },
    "yaml-lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "yamllint -c ../../configuration/yamllint.yaml searxng.settings.yml",
        "cwd": "{projectRoot}"
      }
    }
  }
}
