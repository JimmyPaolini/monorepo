{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["lexico-components"],
  "name": "lexico",
  "projectType": "application",
  "sourceRoot": "applications/lexico/src",
  "tags": [
    "framework:react",
    "framework:tanstack-start",
    "language:typescript"
  ],
  "targets": {
    "analyze-code": {
      "configurations": {
        "check": {
          "commands": [
            "nx run lexico:clean:check",
            "nx run lexico:dependency-cruiser",
            "nx run lexico:format:check",
            "nx run lexico:lint:check",
            "nx run lexico:markdown-lint:check",
            "nx run lexico:spell-check",
            "nx run lexico:squawk",
            "nx run lexico:type-coverage",
            "nx run lexico:typecheck",
            "nx run lexico:yaml-lint"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run lexico:clean:write",
            "nx run lexico:dependency-cruiser",
            "nx run lexico:format:write",
            "nx run lexico:lint:write",
            "nx run lexico:markdown-lint:write",
            "nx run lexico:spell-check",
            "nx run lexico:squawk",
            "nx run lexico:type-coverage",
            "nx run lexico:typecheck",
            "nx run lexico:yaml-lint"
          ],
          "parallel": false
        }
      }
    },
    "build": {
      "description": "Build the application for production",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm build",
        "cwd": "applications/lexico"
      }
    },
    "bundlesize": {
      "cache": true,
      "dependsOn": ["build"],
      "description": "Check bundle size limits",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/dist/applications/lexico/**/*", "default"],
      "options": {
        "command": "npx size-limit",
        "cwd": "applications/lexico"
      }
    },
    "clean": {},
    "dependency-cruiser": {},
    "develop": {
      "description": "Start development server with hot reload",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm develop",
        "cwd": "applications/lexico"
      }
    },
    "format": {
      "configurations": {
        "check": {
          "commands": [
            "nx run lexico:prettier:check",
            "nx run lexico:oxfmt:check",
            "nx run lexico:sqlfluff-format:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run lexico:prettier:write",
            "nx run lexico:oxfmt:write",
            "nx run lexico:sqlfluff-format:write"
          ],
          "parallel": false
        }
      }
    },
    "knip": {},
    "lint": {
      "configurations": {
        "check": {
          "commands": [
            "nx run lexico:eslint:check",
            "nx run lexico:oxlint:check",
            "nx run lexico:sqlfluff-lint:check"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run lexico:eslint:write",
            "nx run lexico:oxlint:write",
            "nx run lexico:sqlfluff-lint:write"
          ],
          "parallel": false
        }
      }
    },
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "sqlfluff-format": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "lint"
        },
        "write": {
          "args": "fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.sql",
        "{workspaceRoot}/configuration/pyproject.toml",
        "sharedGlobals"
      ],
      "options": {
        "command": "uv run --project configuration sqlfluff {args} --config configuration/pyproject.toml {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "sqlfluff-lint": {
      "cache": true,
      "configurations": {
        "check": {
          "args": "lint"
        },
        "write": {
          "args": "fix"
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.sql",
        "{workspaceRoot}/configuration/pyproject.toml",
        "sharedGlobals"
      ],
      "options": {
        "command": "uv run --project configuration sqlfluff {args} --config configuration/pyproject.toml {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "squawk": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/**/*.sql",
        "{workspaceRoot}/configuration/squawk.toml",
        "sharedGlobals"
      ],
      "options": {
        "command": "squawk --config configuration/squawk.toml --include=require-table-schema --exclude-path applications/lexico/supabase/migrations/20251127225025_remote_schema.sql --exclude-path applications/lexico/supabase/migrations/20251127225309_remote_schema.sql {projectRoot}/supabase/migrations/*.sql",
        "cwd": "{workspaceRoot}"
      }
    },
    "start": {
      "description": "Start the production server",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm start",
        "cwd": "applications/lexico"
      }
    },
    "supabase:database-diff": {
      "description": "Generate migration from local database changes",
      "executor": "nx:run-commands",
      "options": {
        "command": "supabase db diff --use-migra-py",
        "cwd": "applications/lexico"
      }
    },
    "supabase:database-reset": {
      "description": "Reset local database and apply all migrations",
      "executor": "nx:run-commands",
      "options": {
        "command": "supabase db reset",
        "cwd": "applications/lexico"
      }
    },
    "supabase:generate-types": {
      "description": "Generate TypeScript types from local Supabase schema",
      "executor": "nx:run-commands",
      "options": {
        "command": "supabase gen types typescript --local > src/lib/database.types.ts",
        "cwd": "applications/lexico"
      }
    },
    "supabase:start": {
      "description": "Start local Supabase development environment",
      "executor": "nx:run-commands",
      "options": {
        "command": "supabase start",
        "cwd": "applications/lexico"
      }
    },
    "supabase:stop": {
      "description": "Stop local Supabase development environment",
      "executor": "nx:run-commands",
      "options": {
        "command": "supabase stop",
        "cwd": "applications/lexico"
      }
    },
    "type-coverage": {},
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "yaml-lint": {}
  }
}
