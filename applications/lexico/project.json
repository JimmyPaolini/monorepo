{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": ["lexico-components"],
  "name": "lexico",
  "projectType": "application",
  "sourceRoot": "applications/lexico/src",
  "tags": [
    "domain:lexico",
    "framework:react",
    "framework:tanstack-start",
    "language:typescript",
    "type:application"
  ],
  "targets": {
    "analyze-code": {},
    "build": {
      "description": "Build the application for production",
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "applications/lexico"
      }
    },
    "bundlesize": {
      "cache": true,
      "dependsOn": ["build"],
      "description": "Check bundle size limits",
      "executor": "nx:run-commands",
      "inputs": ["{workspaceRoot}/dist/applications/lexico/**/*", "default"],
      "options": {
        "command": "npx size-limit",
        "cwd": "applications/lexico"
      }
    },
    "clean": {},
    "dependency-cruiser": {},
    "develop": {
      "description": "Start development server with hot reload",
      "executor": "nx:run-commands",
      "options": {
        "command": "vite dev",
        "cwd": "applications/lexico"
      }
    },
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "preview": {
      "description": "Preview the production build",
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview",
        "cwd": "{projectRoot}"
      }
    },
    "spell-check": {},
    "start": {
      "description": "Start the production server",
      "executor": "nx:run-commands",
      "options": {
        "command": "node .output/server/index.mjs",
        "cwd": "applications/lexico"
      }
    },
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
