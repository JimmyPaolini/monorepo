{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "outDir": "../../dist/out-tsc",
    "paths": {
      "@/*": ["../../packages/lexico-components/src/*"],
      "@monorepo/lexico-components": [
        "../../packages/lexico-components/src/index.ts"
      ],
      "eslint-plugin-better-max-params": [
        "../../configuration/types/eslint-plugin-better-max-params/index.d.ts"
      ],
      "monorepo/configuration/*": ["../../configuration/*"],
      "~/*": ["./src/*"]
    },
    "strict": true,
    "target": "ES2022",
    "types": [
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts",
      "node",
      "vite/client"
    ]
  },
  "exclude": [],
  "extends": "../../configuration/tsconfig.json",
  "include": [
    "eslint.config.ts",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.mts",
    "vitest.config.ts"
  ]
}
