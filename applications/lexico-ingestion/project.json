{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "lexico-ingestion",
  "projectType": "application",
  "sourceRoot": "applications/lexico-ingestion",
  "tags": [
    "domain:lexico",
    "framework:nest-commander",
    "framework:nestjs",
    "generator:nestjs-command-application",
    "language:typescript",
    "type:application"
  ],
  "targets": {
    "analyze-code": {},
    "build": {
      "command": "echo 'lexico-ingestion is a development tool and does not require building'"
    },
    "clean": {},
    "dependency-cruiser": {},
    "eslint": {},
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "start": {
      "cache": false,
      "configurations": {
        "clear": {
          "command": "node --import @swc-node/register/esm-register src/main.ts clear {args}"
        },
        "corpus-scriptorum-ecclesiasticorum-latinorum": {
          "command": "node --import @swc-node/register/esm-register src/main.ts corpus-scriptorum-ecclesiasticorum-latinorum {args}"
        },
        "dictionary": {
          "command": "node --import @swc-node/register/esm-register src/main.ts dictionary {args}"
        },
        "epigraphik-datenbank-clauss-slaby": {
          "command": "node --import @swc-node/register/esm-register src/main.ts epigraphik-datenbank-clauss-slaby {args}"
        },
        "latin-library": {
          "command": "node --import @swc-node/register/esm-register src/main.ts latin-library {args}"
        },
        "lexico-ingestion": {
          "command": "node --import @swc-node/register/esm-register src/main.ts lexico-ingestion {args}"
        },
        "library": {
          "command": "node --import @swc-node/register/esm-register src/main.ts library {args}"
        },
        "literature": {
          "command": "node --import @swc-node/register/esm-register src/main.ts literature {args}"
        },
        "perseus": {
          "command": "node --import @swc-node/register/esm-register src/main.ts perseus {args}"
        },
        "wiktionary": {
          "command": "node --import @swc-node/register/esm-register src/main.ts wiktionary {args}"
        }
      },
      "defaultConfiguration": "lexico-ingestion",
      "description": "Start the Lexico ingestion application or run an ingestion command",
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import @swc-node/register/esm-register src/main.ts lexico-ingestion {args}",
        "cwd": "{projectRoot}"
      }
    },
    "test": {},
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
