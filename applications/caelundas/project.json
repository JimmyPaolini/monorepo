{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "caelundas",
  "projectType": "application",
  "sourceRoot": "applications/caelundas",
  "tags": ["language:typescript"],
  "targets": {
    "clean": {
      "configurations": {
        "check": {
          "commands": ["nx run {projectName}:knip:check"],
          "parallel": true
        },
        "write": {
          "commands": ["nx run {projectName}:knip:write"],
          "parallel": false
        }
      },
      "defaultConfiguration": "check",
      "executor": "nx:run-commands"
    },
    "code-analysis": {
      "configurations": {
        "check": {
          "commands": [
            "nx run {projectName}:clean:check",
            "nx run {projectName}:dependency-analysis",
            "nx run {projectName}:format:check",
            "nx run {projectName}:lint:check",
            "nx run {projectName}:markdown-lint:check",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck",
            "nx run {projectName}:yaml-lint"
          ],
          "parallel": true
        },
        "write": {
          "commands": [
            "nx run {projectName}:clean:write",
            "nx run {projectName}:dependency-analysis",
            "nx run {projectName}:format:write",
            "nx run {projectName}:lint:write",
            "nx run {projectName}:markdown-lint:write",
            "nx run {projectName}:spell-check",
            "nx run {projectName}:type-coverage",
            "nx run {projectName}:typecheck",
            "nx run {projectName}:yaml-lint"
          ],
          "parallel": false
        }
      }
    },
    "dependency-analysis": {},
    "develop": {
      "description": "Run Caelundas locally with .env file",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm develop",
        "cwd": "applications/caelundas"
      }
    },
    "download-ephemeris": {
      "cache": false,
      "description": "Download Swiss Ephemeris data files to data/ephemeris/",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx scripts/download-ephemeris.ts",
        "cwd": "{projectRoot}"
      }
    },
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "start": {
      "description": "Start the Caelundas application",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm start",
        "cwd": "applications/caelundas"
      }
    },
    "test": {
      "configurations": {
        "coverage": {
          "command": "pnpm test:coverage"
        },
        "end-to-end": {
          "command": "pnpm test:end-to-end"
        },
        "integration": {
          "command": "pnpm test:integration"
        },
        "unit": {
          "command": "pnpm test:unit"
        },
        "watch": {
          "command": "pnpm test:watch"
        }
      },
      "description": "Run all tests",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm test",
        "cwd": "applications/caelundas"
      }
    },
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
