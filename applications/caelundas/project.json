{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "caelundas",
  "projectType": "application",
  "sourceRoot": "applications/caelundas",
  "tags": [
    "domain:caelundas",
    "framework:nest-commander",
    "framework:nestjs",
    "generator:nestjs-command-application",
    "language:typescript",
    "type:application"
  ],
  "targets": {
    "analyze-code": {},
    "clean": {},
    "dependency-cruiser": {},
    "download-ephemeris": {
      "cache": false,
      "description": "Download Swiss Ephemeris data files to data/ephemeris/",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx scripts/download-ephemeris.ts",
        "cwd": "{projectRoot}"
      }
    },
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "test": {},
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
