{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "caelundas",
  "projectType": "application",
  "sourceRoot": "applications/caelundas",
  "tags": [
    "framework:nest-commander",
    "framework:nestjs",
    "language:typescript"
  ],
  "targets": {
    "analyze-code": {},
    "clean": {},
    "code-analysis": { "cache": false },
    "dependency-cruiser": {},
    "download-ephemeris": {
      "cache": false,
      "description": "Download Swiss Ephemeris data files to data/ephemeris/",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx scripts/download-ephemeris.ts",
        "cwd": "{projectRoot}"
      }
    },
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "spell-check": {},
    "start": {
      "description": "Start the Caelundas application",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm start",
        "cwd": "applications/caelundas"
      }
    },
    "test": {
      "configurations": {
        "coverage": {
          "command": "pnpm test:coverage"
        },
        "end-to-end": {
          "command": "pnpm test:end-to-end"
        },
        "integration": {
          "command": "pnpm test:integration"
        },
        "unit": {
          "command": "pnpm test:unit"
        },
        "watch": {
          "command": "pnpm test:watch"
        }
      },
      "description": "Run all tests",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm test",
        "cwd": "applications/caelundas"
      }
    },
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
