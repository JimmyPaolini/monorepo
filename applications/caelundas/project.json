{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "caelundas",
  "projectType": "application",
  "sourceRoot": "applications/caelundas",
  "tags": [
    "framework:nest-commander",
    "framework:nestjs",
    "generator:nestjs-command-application",
    "language:typescript"
  ],
  "targets": {
    "analyze-code": {},
    "clean": {},
    "code-analysis": { "cache": false },
    "dependency-cruiser": {},
    "download-ephemeris": {
      "cache": false,
      "description": "Download Swiss Ephemeris data files to data/ephemeris/",
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsx scripts/download-ephemeris.ts",
        "cwd": "{projectRoot}"
      }
    },
    "format": {},
    "knip": {},
    "lint": {},
    "markdown-lint": {},
    "oxfmt": {},
    "oxlint": {},
    "prettier": {},
    "repl": {
      "description": "Start the Caelundas application in REPL mode",
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import @swc-node/register/esm-register src/repl.ts",
        "cwd": "{projectRoot}"
      }
    },
    "spell-check": {},
    "start": {
      "description": "Start the Caelundas application",
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import @swc-node/register/esm-register src/main.ts caelundas",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "configurations": {
        "coverage": {
          "command": "vitest run --coverage"
        },
        "end-to-end": {
          "command": "vitest run end-to-end.test.ts"
        },
        "integration": {
          "command": "vitest run integration.test.ts"
        },
        "unit": {
          "command": "vitest run unit.test.ts"
        },
        "watch": {
          "command": "vitest"
        }
      },
      "description": "Run all tests",
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "{projectRoot}"
      }
    },
    "type-coverage": {},
    "typecheck": {},
    "yaml-lint": {}
  }
}
