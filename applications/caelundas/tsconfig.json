{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@caelundas/*": ["./*"],
      "@monorepo/conformance/*": ["../../tools/conformance/*"],
      "monorepo/configuration/*": ["../../configuration/*"]
    },
    "target": "esnext",
    "types": ["node", "vitest/globals"]
  },
  "exclude": ["dist", "node_modules", "output"],
  "extends": "../../configuration/tsconfig.base.json",
  "include": [
    "eslint.config.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "testing/**/*.ts",
    "vitest.config.ts"
  ]
}
