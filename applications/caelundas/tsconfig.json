{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@caelundas/*": ["./*"]
    },
    "target": "esnext",
    "types": ["node"]
  },
  "exclude": ["dist", "node_modules", "output"],
  "extends": "../../tsconfig.base.json",
  "include": [
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "testing/**/*.ts",
    "vitest.config.ts"
  ]
}
