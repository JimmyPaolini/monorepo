{
  "name": "caelundas",
  "version": "0.0.1",
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@photostructure/tz-lookup": "^11.4.0",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "nest-commander": "^3.20.1",
    "reflect-metadata": "^0.2.2",
    "sweph": "2.10.3-b-1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nx/eslint-plugin": "^22.7.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.13",
    "@types/lodash": "^4.17.23",
    "@types/node": "^22.19.1",
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.3"
  },
  "scripts": {
    "develop": "set -a && source .env && set +a && node --import @swc-node/register/esm-register src/main.ts caelundas",
    "start": "node --import @swc-node/register/esm-register src/main.ts caelundas",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:end-to-end": "vitest run end-to-end.test.ts",
    "test:integration": "vitest run integration.test.ts",
    "test:unit": "vitest run unit.test.ts",
    "test:watch": "vitest"
  },
  "type": "module",
  "typeCoverage": {
    "atLeast": 99.46,
    "ignoreCatch": true,
    "ignoreFiles": [
      "**/*.spec.ts",
      "**/*.test.ts",
      "**/testing/**"
    ],
    "strict": true
  }
}
