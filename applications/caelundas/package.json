{
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@photostructure/tz-lookup": "^11.5.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "nest-commander": "^3.20.1",
    "reflect-metadata": "^0.2.2",
    "sweph": "^2.10.3-b-1",
    "tsx": "^4.22.3",
    "unplugin-swc": "^1.5.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.23",
    "@nx/eslint-plugin": "^22.7.3",
    "@swc/core": "^1.15.40",
    "@swc/helpers": "^0.5.21",
    "@swc-node/register": "^1.11.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "name": "caelundas",
  "scripts": {
    "start": "node --import @swc-node/register/esm-register src/main.ts caelundas",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:end-to-end": "vitest run end-to-end.test.ts",
    "test:integration": "vitest run integration.test.ts",
    "test:unit": "vitest run unit.test.ts",
    "test:watch": "vitest"
  },
  "type": "module",
  "typeCoverage": {
    "atLeast": 99.46,
    "ignoreCatch": true,
    "ignoreFiles": [
      "**/*.spec.ts",
      "**/*.test.ts",
      "**/testing/**"
