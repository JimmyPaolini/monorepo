{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "audit": {
    "cacheMaxAgeDays": 7,
    "deadCodeBaseline": null,
    "dupesBaseline": null,
    "gate": "all",
    "healthBaseline": null,
  },
  "duplicates": {
    "crossLanguage": true,
    "ignore": ["packages/*/src/modules/database/migrations/**/*.ts"],
    "ignoreDefaults": true,
    "ignoreImports": true,
    "minLines": 12,
    "minOccurrences": 2,
    "minTokens": 24,
    "mode": "semantic",
    "skipLocal": true,
    "threshold": 6,
  },
  "entry": [
    "**/.size-limit.cjs",
    "**/applications/*/src/modules/**/*.module.ts",
    "**/src/main.ts",
    ".devcontainer/scripts/**/*.{js,mjs,ts,sh}",
    ".pnpmfile.mjs",
    "applications/*/scripts/**/*.{js,mjs,ts,sh}",
    "applications/*/src/repl.ts",
    "configuration/commitlint.config.ts",
    "configuration/dependency-cruiser.cjs",
    "configuration/eslint.config.js",
    "configuration/eslint.config.ts",
    "configuration/lint-staged.config.ts",
    "configuration/oxfmt.config.ts",
    "configuration/oxlint.config.ts",
    "configuration/prettier.config.ts",
    "configuration/stylelint.config.cjs",
    "configuration/syncpack.config.cjs",
    "configuration/vitest.config.ts",
    "packages/**/scripts/**/*.{js,mjs,ts,sh}",
    "packages/**/testing/**/*.ts",
    "packages/lexico-entities/src/modules/database/migrations/**/*.ts",
    "release.config.cjs",
    "scripts/**/*.{js,mjs,ts,sh}",
    "tools/conformance/src/generators/**/templates/**",
    "validate-branch-name.config.cjs",
  ],
  "health": {
    "coverage": "coverage/coverage-final.json",
    "coverageRoot": null,
    "crapRefactorBand": 3,
    "ignore": [
      "**/__generated__/**",
      "**/coverage/**",
      "**/dist/**",
      "**/src/lib/database.types.ts",
      "**/src/routeTree.gen.ts",
    ],
    "maxCognitive": 12,
    "maxCrap": 16,
    "maxCyclomatic": 8,
    "ownership": {
      "botPatterns": [
        "*\\[bot\\]*",
        "*-service-account*",
        "dependabot*",
        "github-actions*",
        "renovate*",
        "svc-*",
      ],
      "emailMode": "handle",
    },
    "suggestInlineSuppression": false,
    "thresholdOverrides": [],
  },
  "ignoreDependencies": [
    "@caelundas/src",
    "@caelundas/testing",
    "@commitlint/config-conventional",
    "@nx/eslint-plugin",
    "@nx/js",
    "@nx/vitest",
    "@nx/web",
    "@photostructure/tz-lookup",
    "@semantic-release/changelog",
    "@semantic-release/commit-analyzer",
    "@semantic-release/git",
    "@semantic-release/github",
    "@semantic-release/npm",
    "@semantic-release/release-notes-generator",
    "@size-limit/file",
    "@swc/helpers",
    "@swc-node/register",
    "@testcontainers/postgresql",
    "@typescript-eslint/parser",
    "commitlint-plugin-gitmoji",
    "commitlint-plugin-tense",
    "jiti",
    "license-checker",
    "lodash",
    "markdownlint-cli2",
    "pg",
    "pino-pretty",
    "pluralize",
    "squawk-cli",
    "stylelint",
    "stylelint-config-standard",
    "stylelint-config-tailwindcss",
    "tailwindcss-animate",
    "tslib",
    "tsx",
    "type-coverage",
    "typeorm-naming-strategies",
    "unplugin-swc",
    "vitest",
    "zod",
  ],
  "ignoreExports": [
    {
      "exports": ["typedObjectKeys"],
      "file": "**/src/modules/caelundas/caelundas.symbol-constants.ts",
    },
    {
      "exports": ["*"],
      "file": "**/src/routeTree.gen.ts",
    },
    {
      "exports": ["*"],
      "file": "**/src/lib/database.types.ts",
    },
    {
      "exports": ["*"],
      "file": "**/src/lib/auth.ts",
    },
    {
      "exports": ["*"],
      "file": "**/src/lib/bookmarks.ts",
    },
    {
      "exports": ["*"],
      "file": "**/src/lib/supabase.ts",
    },
    {
      "exports": ["*"],
      "file": "**/src/modules/database/database.module.ts",
    },
    {
      "exports": ["*"],
      "file": "**/src/modules/entities/entities.module.ts",
    },
  ],
  "ignoreExportsUsedInFile": true,
  "ignorePatterns": [
    "**/*.min.js",
    "**/.agents/skills/**/scripts/**",
    "**/.claude/skills/**/scripts/**",
    "**/.github/skills/**/scripts/**",
    "**/.nx/**",
    "**/.opencode/skills/**/scripts/**",
    "**/.terraform/**",
    "**/.venv/**",
    "**/applications/lexico-ingestion/data/**",
    "**/applications/lexico-ingestion/src/modules/library/library.constants.ts",
    "**/applications/lexico-ingestion/src/modules/literature/literature.constants.ts",
    "**/build/**",
    "**/conformance/**/templates/**",
    "**/coverage/**",
    "**/data/library/**",
    "**/data/wikipedia/**",
    "**/data/wiktionary/**",
    "**/dist/**",
    "**/documentation/skills/**/scripts/**",
    "**/helm/**/templates/**",
    "**/library.json",
    "**/node_modules/**",
    "**/pnpm-lock.yaml",
    "**/src/**/*.constants.ts",
    "**/src/**/*.types.ts",
    "**/src/lib/database.types.ts",
    "**/src/routeTree.gen.ts",
    "**/testing/**",
    "**/tmp/**",
    "**/vite.config.*.timestamp*",
    "**/vitest.config.*.timestamp*",
    ".github/copilot-instructions.md",
    ".github/skills/**",
    "applications/affirmations/**",
    "applications/JimmyPaolini/**",
    "CHANGELOG.md",
    "documentation/skills/link-workspace-packages/**",
    "documentation/skills/monitor-ci/**",
    "documentation/skills/nx-generate/**",
    "documentation/skills/nx-import/**",
    "documentation/skills/nx-plugins/**",
    "documentation/skills/nx-run-tasks/**",
    "documentation/skills/nx-workspace/**",
    "notepads/**",
  ],
  "publicPackages": [],
  "rules": {
    "circular-dependencies": "warn",
    "private-type-leaks": "off",
    "unresolved-imports": "warn",
    "unused-dependencies": "warn",
    "unused-exports": "warn",
    "unused-files": "warn",
    "unused-types": "warn",
  },
  "usedClassMembers": [
    {
      "extends": "CommandRunner",
      "members": ["run"],
    },
    "ingest",
  ],
}
