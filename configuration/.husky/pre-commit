#!/usr/bin/env sh
set -e

NOISE_FILTER='\(node:[0-9]+\) Warning: The .NO_COLOR|\(Use .node --trace-warnings|Your AI agent configuration is outdated'
TMP_OUTPUT_FILE="$(mktemp)"
trap 'rm -f "$TMP_OUTPUT_FILE"' EXIT

set +e
nx run monorepo:lint-staged >"$TMP_OUTPUT_FILE" 2>&1
LINT_STAGED_EXIT_CODE=$?
set -e

grep -vE "$NOISE_FILTER" "$TMP_OUTPUT_FILE" \
	| awk '{ gsub(/\033\[[0-9;]*[mK]/, ""); print }' \
	| tee last-lint-staged-errors.txt

exit "$LINT_STAGED_EXIT_CODE"
