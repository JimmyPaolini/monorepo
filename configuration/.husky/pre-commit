set -e

# ⏱️ Log timestamp
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S %z')
printf '[%s] pre-commit\n' "$TIMESTAMP"

# 🔐 Check GPG git signing configuration
REPOSITORY_ROOT="$(git rev-parse --show-toplevel)"
"$REPOSITORY_ROOT/scripts/git/check-commit-signing-configuration.sh"

# 🗒️ Clear notepads
git restore --staged notepads/notepad.jsonc || true
git restore --staged notepads/notepad.md || true
git restore --staged notepads/notepad.py || true
git restore --staged notepads/notepad.sh || true
git restore --staged notepads/notepad.sql || true
git restore --staged notepads/notepad.ts || true

EXIT_CODE=0

# 📏 Measure code
nx run monorepo:measure-code:write || EXIT_CODE=$?
git add README.md

# 🧹 Check staged files
NX_PERF_LOGGING=false NODE_OPTIONS='--import=tsx' lint-staged --config configuration/lint-staged.config.ts --continue-on-error > last-lint-staged-output.log 2>&1 || EXIT_CODE=$?

# 🖨️ Log output
LAST_LINT_STAGED_OUTPUT=$(cat last-lint-staged-output.log \
  | grep -vE '\(node:[0-9]+\) Warning: The .NO_COLOR' \
  | grep -vE '\(Use .node --trace-warnings' \
  | grep -vE 'Your AI agent configuration is outdated' \
  | perl -pe 's/\x1B\[[0-9;]*[a-zA-Z]//g' \
  | perl -0777 -pe 's/\n{3,}/\n\n/g')

printf "%s\n" "$LAST_LINT_STAGED_OUTPUT"
printf '[%s] pre-commit\n%s\n' "$TIMESTAMP" "$LAST_LINT_STAGED_OUTPUT" > last-lint-staged-output.log

# 🚫 Exit
exit "$EXIT_CODE"
